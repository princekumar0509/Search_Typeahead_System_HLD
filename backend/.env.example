# Copy to .env and adjust as needed.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/typeahead

# Cache
CACHE_TTL_SECONDS=60
CACHE_VIRTUAL_NODES=150
CACHE_NODE_NAMES=node1,node2,node3

# Batch writer
BATCH_FLUSH_INTERVAL_SECONDS=30
BATCH_FLUSH_THRESHOLD=100

# API limits
SUGGESTION_LIMIT=10
TRENDING_LIMIT=10
